<controls:MetroWindow  xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                       x:Class="Sensor.Views.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sensor.Views"
        xmlns:viewmodels="clr-namespace:Sensor.ViewModels"
        mc:Ignorable="d" FontSize="16"
        Title="Shell" Height="600" Width="800">
    
    <controls:MetroWindow.DataContext>
        <viewmodels:ShellViewModel />
    </controls:MetroWindow.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  Header="Workstation Deployment Assignment" 
                  Padding="15">
            <StackPanel Grid.IsSharedSizeScope="True">

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="API URL:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Group Key:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding GroupKey, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="End User Name:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding EndUser, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Organizational Unit:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Units}" SelectedValuePath="Id" SelectedValue="{Binding SelectedUnitId}" Height="26"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Network Profile:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding NetworkTypes}" SelectedValuePath="Id" SelectedValue="{Binding SelectedNetworkTypeId}" Height="26"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Device Type:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding DeviceTypes}" SelectedValuePath="Id" SelectedValue="{Binding SelectedDeviceTypeId}" Height="26"/>
                </Grid>

                <Button Content="Fetch Parameters" 
                        Margin="1"
                        Command="{Binding FetchParametersCommand}" 
                        Height="32" FontWeight="Bold" 
                        Background="#007ACC" Foreground="White" BorderThickness="0"/>

                <Button Content="Run System Audit &amp; Sync" 
                        Margin="1"
                        Command="{Binding SubmitTelemetryCommand}" 
                        Height="32" FontWeight="Bold" 
                        Background="#007ACC" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </GroupBox>

        <StatusBar Grid.Row="1" Background="#E9EAEF" Margin="0,10,0,0" Padding="5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="Medium" Foreground="#444444"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>

</controls:MetroWindow>
